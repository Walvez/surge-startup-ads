#!name=影视去广告
#!desc=墨鱼 FakeiOSAds 的 Surge 转换版
#!author=ddgksf2013
#!category=去广告

[URL Rewrite]
^http:\/\/[a-zA-Z0-9_-]+(\.[a-zA-Z0-9_-]+){1,4}(:\d+)?\/.*?\/v\d\/(version|notice\?|top_notice\?|advert\?position=[^2]+) - reject-200

[Body Rewrite]
http-response-jq ^http:\/\/[a-zA-Z0-9_-]+(\.[a-zA-Z0-9_-]+){1,4}(:\d+)?\/api\/v\d\/config\/getConfigList\.do '.data |= map(select(.keyName | test("config\\.(ad|search|recommend)") | not))'

[MITM]
hostname = %APPEND% app.dsx.ac
